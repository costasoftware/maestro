{
    "name": "@costasoftware/maestro-core",
    "version": "0.0.1",
    "description": "Runtime kernel for the Maestro agent platform — tool envelope, definition factory, base context.",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "lint": "echo \"(lint not yet configured)\" && exit 0",
        "typecheck": "tsc -p tsconfig.build.json --noEmit",
        "clean": "rm -rf dist .turbo *.tsbuildinfo"
    },
    "devDependencies": {
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "publishConfig": {
        "access": "public"
    }
}
