{
    "name": "maestro-react",
    "version": "0.1.0-beta.0",
    "description": "React surface for the Maestro agent runtime. P1 ships the MaestroChatProtocol — a wire-format-neutral event vocabulary shared across backends. Hooks, transports, and components land in later phases.",
    "license": "Apache-2.0",
    "author": "Costa Software",
    "homepage": "https://github.com/costasoftware/maestro/tree/main/packages/maestro-react#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/costasoftware/maestro.git",
        "directory": "packages/maestro-react"
    },
    "bugs": {
        "url": "https://github.com/costasoftware/maestro/issues"
    },
    "keywords": [
        "maestro",
        "react",
        "ai",
        "agent",
        "chat",
        "protocol",
        "sse",
        "streaming"
    ],
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./protocol": {
            "types": "./dist/protocol.d.ts",
            "import": "./dist/protocol.js"
        },
        "./transports": {
            "types": "./dist/transports/index.d.ts",
            "import": "./dist/transports/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "lint": "echo \"(lint not yet configured)\" && exit 0",
        "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json",
        "clean": "rm -rf dist .turbo *.tsbuildinfo",
        "prepublishOnly": "rm -rf dist .turbo *.tsbuildinfo && tsc -p tsconfig.build.json"
    },
    "peerDependencies": {
        "ai": "^6.0.0",
        "react": ">=18",
        "react-dom": ">=18"
    },
    "peerDependenciesMeta": {
        "ai": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/dom": "^10.0.0",
        "@testing-library/react": "^16.0.0",
        "@types/node": "^20.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "jsdom": "^25.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "publishConfig": {
        "access": "public"
    }
}
